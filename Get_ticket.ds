 application "Get ticket"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "Asia/Kolkata"
 	time format = "24-hr"
 	forms
	{
		form Passenger
		{
			success message = "Passenger Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			must have Passenger_Name
			(
    			type = name
				displayname = "Passenger Name"
     			prefix
     			(
	     			 type = prefix
	     			 displayname ="Prefix"
	     			 visibility = false
	     			 value = {"Mr.","Mrs.","Ms."}
     			) 
     			first_name
     			(
	     			 type = first_name
	     			 displayname ="First Name"
     			) 
     			last_name
     			(
	     			 type = last_name
	     			 displayname ="Last Name"
     			) 
     			suffix
     			(
	     			 type = suffix
	     			 displayname ="Suffix"
	     			 visibility = false
     			) 
	 			row = 1
	 			column = 1   
				width = large
				personal data = true
			)
			must have Date_of_journey
			(
    			type = date
				displayname = "Date of journey"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Gender
			(
				type = picklist
				maxchar = 100
				values = {"Male","Female","Trangender","Another gender"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Date_of_birth
			(
    			type = date
				displayname = "Date of birth"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Age
			(
				type = number
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Phone_number1
			(
    			type = phonenumber
				displayname = "Phone number"
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have ID_Proof
			(
				type = picklist
				displayname = "ID Proof"
				maxchar = 100
				values = {"Aadhar Card","PAN Card","Driving Licence","Voter ID (EPIC)","Passport","Ration Card"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			Aadhar_number
			(
				type = number
				displayname = "Aadhar number"
				maxchar = 12
	 			row = 1
	 			column = 1   
				width = medium
			)
			Driving
			(
    			type = text
				displayname = "Driving Licence"
	 			row = 1
	 			column = 1   
				width = medium
			)
			PAN_Card
			(
    			type = text
				displayname = "PAN Card"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Passport
			(
    			type = text
	 			row = 1
	 			column = 1   
				width = medium
			)
			Ration_Card
			(
    			type = text
				displayname = "Ration Card"
	 			row = 1
	 			column = 1   
				width = medium
			)
			Voter_ID
			(
    			type = text
				displayname = "Voter ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Email1
			(
    			type = email
				displayname = "Email "
				maxchar = 80
	 			row = 1
	 			column = 1   
				width = medium
				personal data = true
			)
			must have From_Station
			(
				type = picklist
				displayname = "From Stop"
				maxchar = 100
				values = {"New delhi","Ahamadabad","Hyderabad","Kochi","Mumbai","Chennai","Bengaluru"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have To_Station
			(
				type = picklist
				displayname = "To Stop"
				maxchar = 100
				values = {"Mumbai","Chennai","Bengaluru","Ahamadabad","New delhi","Hyderabad","Kochi"}
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Select_Seat
			(
				type = list	
				displayname = "Select Seat "
				values = {"Seat 1","Seat 2","Seat 3","Seat 4","Seat 5","Seat 6","Seat 7","Seat 8","Seat 9","Seat 10","Seat 11","Seat 12","Seat 13","Seat 14","Seat 15","Seat 16","Seat 17","Seat 18","Seat 19","Seat 20"}
				height = 60px
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Class
			(
				type = picklist
				maxchar = 100
				values = {"AC Sleeper","AC Chair","Non -AC Sleeper","Non -AC Chair"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Food_preferences
			(
				type = picklist
				displayname = "Food preferences"
				maxchar = 100
				values = {"Veg","Non - veg","Any (veg or non-veg)"}
	 			row = 1
	 			column = 1   
				width = medium
			)
			Ticket_price
			(
				displayname = "Ticket price"
				type = INR
				format = commadotindian
				qrcode = true
				show onload = true
				camera = primary
				preview duration = 5
				show gallery = true
				switch camera = true
				submit onscan = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			QR_Code
			(
				type = qrcode
				displayname = "QR Code"
				value = "https://creator.zoho.in/appbuilder/manikandan_zentegra411/get-ticket/workflowbuilder/Ticket_price1/edit"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form QR_code
		{
			displayname = "QR code"
			success message = "Qr Code Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Bar_code
			(
				type = barcode
				displayname = "Bar code"
				value = "${ID}"
				barcode type = "Code-128"
	 			row = 1
	 			column = 1   
				width = medium
			)
			must have Image_ID
			(
				type = number
				displayname = "Image ID"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form test
		{
			success message = "Test Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			Currency
			(
				type = INR
				format = commadotindian
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
	}
	reports
	{
		default list All_Passengers
		{
			displayName = "All Passengers"
			show all rows from Passenger    
			(
				Passenger_Name  as "Passenger Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				Phone_number1 as "Phone number"
				(
					displayformat = plainnumber 
					linktodial = enable
				)
				Email1 as "Email "
				From_Station as "From Stop"
				To_Station as "To Stop"
				Ticket_price as "Ticket price"
				Class
				QR_Code as "QR Code"
				Age
				Date_of_birth as "Date of birth"
				Gender
				ID_Proof as "ID Proof"
				Food_preferences as "Food preferences"
				PAN_Card as "PAN Card"
				Passport
				Ration_Card as "Ration Card"
				Voter_ID as "Voter ID"
				Driving as "Driving Licence"
				Aadhar_number as "Aadhar number"
				Date_of_journey as "Date of journey"
				Select_Seat as "Select Seat "
			)
		}
		default list All_Qr_Codes
		{
			displayName = "All Qr Codes"
			show all rows from QR_code    
			(
				Bar_code as "Bar code"
				Image_ID as "Image ID"
			)
		}
		default list All_Tests
		{
			displayName = "All Tests"
			show all rows from test    
			(
				Currency
			)
		}
	}
	pages
	{
		page frontend
		{
			displayname = "frontend"
			Content="<zml    \t\t\n\t\t\n\t\t\n\t\t\n\t\t\n>\n\t<layout>\n\t<row>\n\t<column\n   \t\t width='100%'\n   \t>\n\t<dsp id='html_snippet' elementName='HTML Snippet'\n bgColor=\"#FFFFFF\" \n>\n\t<![CDATA[htmlpage html_snippet()\ncontent\n&lt;%{\n\t%&gt;\n&lt;head&gt;\n    &lt;meta charset=&quot;UTF-8&quot;&gt;\n    &lt;title&gt;Ticket Bill&lt;/title&gt;\n    &lt;style&gt;\n        body {\n            font-family: &quot;Segoe UI&quot;, Arial, sans-serif;\n            background: #f4f6f8;\n            padding: 20px;\n        }\n\n        .invoice-box {\n            max-width: 600px;\n            margin: auto;\n            background: #ffffff;\n            padding: 25px;\n            border-radius: 10px;\n            box-shadow: 0 8px 20px rgba(0,0,0,0.08);\n        }\n\n        .header {\n            text-align: center;\n            border-bottom: 2px dashed #ddd;\n            padding-bottom: 15px;\n        }\n\n        .header h1 {\n            margin: 0;\n            color: #2c3e50;\n        }\n\n        .header p {\n            margin: 4px 0;\n            color: #777;\n            font-size: 14px;\n        }\n\n        .details {\n            margin-top: 20px;\n        }\n\n        .details table {\n            width: 100%;\n            border-collapse: collapse;\n            font-size: 14px;\n        }\n\n        .details td {\n            padding: 10px;\n            border-bottom: 1px solid #eee;\n        }\n\n        .details td:first-child {\n            color: #555;\n            width: 40%;\n        }\n\n        .route {\n            background: #f0f4ff;\n            padding: 12px;\n            border-radius: 8px;\n            margin: 20px 0;\n            text-align: center;\n            font-weight: bold;\n            color: #34495e;\n        }\n\n        .amount {\n            text-align: right;\n            margin-top: 20px;\n        }\n\n        .amount h2 {\n            margin: 0;\n            color: #27ae60;\n        }\n\n        .footer {\n            margin-top: 25px;\n            text-align: center;\n            font-size: 13px;\n            color: #777;\n        }\n\n        .badge {\n            display: inline-block;\n            padding: 5px 12px;\n            background: #27ae60;\n            color: #fff;\n            border-radius: 20px;\n            font-size: 12px;\n            margin-top: 8px;\n        }\n    &lt;/style&gt;\n&lt;/head&gt;\n&lt;body&gt;\n\n&lt;div class=&quot;invoice-box&quot;&gt;\n\n    &lt;div class=&quot;header&quot;&gt;\n        &lt;h1&gt;Travel Ticket Bill&lt;/h1&gt;\n        &lt;p&gt;Thank you for choosing our service&lt;/p&gt;\n        &lt;span class=&quot;badge&quot;&gt;PAID&lt;/span&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;details&quot;&gt;\n        &lt;table&gt;\n            &lt;tr&gt;\n                &lt;td&gt;Passenger Name&lt;/td&gt;\n                &lt;td&gt;Manikandan&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n                &lt;td&gt;Phone Number&lt;/td&gt;\n                &lt;td&gt;+91 86089 44648&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n                &lt;td&gt;Email&lt;/td&gt;\n                &lt;td&gt;passenger@email.com&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n                &lt;td&gt;Booking ID&lt;/td&gt;\n                &lt;td&gt;#TRV10245&lt;/td&gt;\n            &lt;/tr&gt;\n            &lt;tr&gt;\n                &lt;td&gt;Journey Date&lt;/td&gt;\n                &lt;td&gt;12 Feb 2026&lt;/td&gt;\n            &lt;/tr&gt;\n        &lt;/table&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;route&quot;&gt;\n        Chennai \u279D Bengaluru\n    &lt;/div&gt;\n\n    &lt;div class=&quot;amount&quot;&gt;\n        &lt;p&gt;Total Amount&lt;/p&gt;\n        &lt;h2&gt;\u20B9 249&lt;/h2&gt;\n    &lt;/div&gt;\n\n    &lt;div class=&quot;footer&quot;&gt;\n        &lt;p&gt;This is a system generated bill.&lt;/p&gt;\n        &lt;p&gt;Have a safe &amp; happy journey &lt;/p&gt;\n    &lt;/div&gt;\n\n&lt;/div&gt;\n\n&lt;/body&gt;\n&lt;/html&gt;\n&lt;%\n\n}%&gt;]]>\n</dsp>\n</column>\n</row>\n</layout>\n</zml>"
		}
	}


