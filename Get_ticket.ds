			}
			ID_Proof_validation as "ID Proof validation"
			{
				type =  form
				form = Passenger

				record event = on add or edit

				on user input of ID_Proof
				{
					actions 
					{
						custom deluge script
						(
											if(ID_Proof == "Aadhar Card")
										{
											show Aadhar_number;
										}
										else
										{
											hide Aadhar_number;
										}
										// hide Driving;
										if(ID_Proof == "Driving Licence")
										{
											show Driving;
										}
										else
										{
											hide Driving;
										}
										// hide PAN_Card;
										if(ID_Proof == "PAN Card")
										{
											show PAN_Card;
										}
										else
										{
											hide PAN_Card;
										}
										// hide Passport;
										// hide Ration_Card;
										if(ID_Proof == "Ration Card")
										{
											show Ration_Card;
										}
										else
										{
											hide Ration_Card;
										}
										// hide Voter_ID;
										if(ID_Proof == "Voter ID (EPIC)")
										{
											show Voter_ID;
										}
										else
										{
											hide Voter_ID;
										}
										if(ID_Proof == "Passport")
										{
											show Passport;
										}
										else
										{
											hide Passport;
										}
										// seats = input.Select_Seat.size();
										// if(Ticket_price == null)
										// {
										// 	input.Ticket_price = 0;
										// }
										// Ticket = input.Ticket_price * seats;
										// info Ticket;
						)
					}
				}

			}
