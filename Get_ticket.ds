		workflow
		{
		form
		{
			Load_of_hide_fields as "Load-of-hide-fields"
			{
				type =  form
				form = Passenger

				record event = on add or edit

				on load
				{
					actions 
					{
						custom deluge script
						(
											hide Aadhar_number;
										hide Driving;
										hide PAN_Card;
										hide Ration_Card;
										hide Voter_ID;
										hide Passport;
										disable Ticket_price;
